{
  "name": "matlab-style-sections",
  "displayName": "MATLAB Style Sections",
  "description": "MATLAB-like %% sections with dividers, folding, and emphasized titles across languages.",
  "version": "0.0.8",
  "publisher": "YoussefElgedawy",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yismailsaadelgedawy/VSCode-Sections-Extension.git"
  },
  "homepage": "https://github.com/yismailsaadelgedawy/VSCode-Sections-Extension",
  "bugs": {
    "url": "https://github.com/yismailsaadelgedawy/VSCode-Sections-Extension/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "MATLAB Style Sections",
      "properties": {
        "matlabSections.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable %% section rendering and folding."
        },
        "matlabSections.decorateHeader": {
          "type": "boolean",
          "default": true,
          "description": "Render section header line text with stronger style."
        },
        "matlabSections.showDivider": {
          "type": "boolean",
          "default": true,
          "description": "Render a horizontal divider under each %% section header."
        },
        "matlabSections.indentAware": {
          "type": "boolean",
          "default": true,
          "description": "Only fold lines that are indented at least as much as the section header."
        },
        "matlabSections.maxLineCount": {
          "type": "number",
          "default": 20000,
          "minimum": 1,
          "description": "Skip section parsing for very large files above this line count."
        },
        "matlabSections.tracePerformance": {
          "type": "boolean",
          "default": false,
          "description": "Write performance diagnostics to the MATLAB Style Sections output channel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.86.0",
    "typescript": "^5.3.3"
  }
}
